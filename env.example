# --- Banco (uma única URL; o app usa pydantic-settings: DATABASE_URL)
#
# Backend no Docker + MySQL no HOST da VPS (outro database, ex.: sicat):
# DATABASE_URL=mysql+pymysql://root:SENHA@host.docker.internal:3306/sicat
#
# Se a senha tiver caracteres especiais na URL, encode (ex.: ! → %21, @ → %40):
# DATABASE_URL=mysql+pymysql://root:Senha%21forte@host.docker.internal:3306/sicat
#
# Backend com docker-compose.host-network.yml (MySQL só em 127.0.0.1):
# DATABASE_URL=mysql+pymysql://root:SENHA@127.0.0.1:3306/sicat
#
# MySQL dentro do Docker (docker-compose.bundled-mysql.yml):
# DATABASE_URL=mysql+pymysql://sicat_user:sicat_password@db:3306/sicat
#
# Sem Docker, na mesma máquina:
DATABASE_URL=mysql+pymysql://usuario:senha@127.0.0.1:3306/sicat

SECRET_KEY=sua-chave-secreta-aqui-altere-em-producao
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=72
SUAP_API_URL=https://suap.ifrn.edu.br
