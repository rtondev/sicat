# DATABASE_URL: pydantic-settings lê esta variável.
#
# Docker (MySQL no host da máquina / VPS):
# DATABASE_URL=mysql+pymysql://usuario:senha@host.docker.internal:3306/sicat
# Senha com caracteres especiais: codifique na URL (! → %21, @ → %40, etc.)
#
# Mesma máquina sem Docker (venv + uvicorn):
DATABASE_URL=mysql+pymysql://usuario:senha@127.0.0.1:3306/sicat

SECRET_KEY=sua-chave-secreta-aqui-altere-em-producao
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=72
SUAP_API_URL=https://suap.ifrn.edu.br
